# ClickHouse
CH_HOST=localhost
CH_PORT=8123
CH_DB=signal
CH_USER=default
CH_PASSWORD=

# Postgres (used by Cost lens for pricing rates)
PG_DSN=postgresql://postgres:@localhost:5433/signal

# Worker run loop
WORKER_BATCH=5000
WORKER_POLL_SEC=2.0
WORKER_STATE_DIR= #watermark folder

SIGNAL_PII_NER_MODEL=gravitee-io/bert-small-pii-detection       # default; set to gravitee-io/bert-small-pii-detection for the recommended tight ensemble
SIGNAL_PII_BATCH=4                         # thread-pool width for analyze_batch
SIGNAL_PII_CACHE_MAX=20000                 # LRU cap on the per-worker content cache

# Quality lens (local-model semantic scoring; see signal_worker/scorers.py)
SIGNAL_QUALITY_SEMANTIC=true               # false = mechanical metrics only (no torch needed)
SIGNAL_QUALITY_SAMPLE=1.0                  # fraction of spans semantically scored (deterministic by span_id)
SIGNAL_QUALITY_NLI_MODEL=MoritzLaurer/DeBERTa-v3-base-mnli-fever-anli   # faithfulness/coherence; FEVER-trained (benchmarked best)
SIGNAL_QUALITY_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
SIGNAL_QUALITY_RELEVANCE_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
SIGNAL_QUALITY_BATCH=32                    # model inference batch size
SIGNAL_QUALITY_CACHE_MAX=20000             # LRU cap on the scoring cache
