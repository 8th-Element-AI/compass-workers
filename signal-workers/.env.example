# ClickHouse
CH_HOST=localhost
CH_PORT=8123
CH_DB=signal
CH_USER=default
CH_PASSWORD=

# Postgres (used by Cost lens for pricing rates)
PG_DSN=postgresql://postgres:@localhost:5433/signal

# Worker run loop
WORKER_BATCH=5000
WORKER_POLL_SEC=2.0
WORKER_STATE_DIR= #checkpoint folder

SIGNAL_PII_NER_MODEL=gravitee-io/bert-small-pii-detection       # default; set to gravitee-io/bert-small-pii-detection for the recommended tight ensemble
SIGNAL_PII_BATCH=4                         # thread-pool width for analyze_batch
SIGNAL_PII_CACHE_MAX=20000                 # LRU cap on the per-worker content cache
