# ClickHouse
CH_HOST=localhost
CH_PORT=8123
CH_DB=signal
CH_USER=default
CH_PASSWORD=

# Postgres (used by Cost lens for pricing rates)
PG_DSN=postgresql://postgres:@localhost:5433/signal

# Worker run loop
WORKER_BATCH=5000
WORKER_POLL_SEC=2.0

SIGNAL_PII_NER_MODEL=gravitee-io/bert-small-pii-detection
SIGNAL_PII_BATCH_SIZE=4
SIGNAL_PII_CACHE_MAX=20000

SIGNAL_TOXICITY_BATCH_SIZE=32
SIGNAL_TOXICITY_CACHE_MAX=10000

# ── Toxicity — device + perf ─────────────────────────────────────
SIGNAL_TOXICITY_DEVICE=cuda
SIGNAL_TOXICITY_ONNX_PROVIDER=auto
SIGNAL_TOXICITY_MAX_LENGTH=512
SIGNAL_TOXICITY_FP16=true
SIGNAL_TOXICITY_BATCH_SIZE=32

# ── Toxicity — model paths ───────────────────────────────────────
# Set the root once; the four paths below are relative to it unless
# absolute. In a container with /opt/models mounted, set the root and
# leave the rest at defaults.
SIGNAL_TOXICITY_MODELS_ROOT=/opt/models
SIGNAL_TOXICITY_PI_PATH=prompt_injection
SIGNAL_TOXICITY_MOD_PATH=minilm_toxic_spam


# ── Toxicity — BERT review thresholds (drive 0/1 verdicts) ──────
SIGNAL_TOXICITY_PI_THRESHOLD=0.50
SIGNAL_TOXICITY_HARMFUL_THRESHOLD=0.50