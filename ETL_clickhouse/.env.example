# ── ClickHouse connection ─────────────────────────────────────────────────────
CH_HOST=localhost
CH_PORT=8123
CH_USER=default
CH_PASSWORD=

# ── Source: OTel Collector writes here by default ─────────────────────────────
CH_SOURCE_DB=default
CH_SOURCE_TABLE=otel_traces

# ── Destination: Compass raw spans ────────────────────────────────────────────
CH_DEST_DB=compass
CH_DEST_TABLE=compass_raw_spans

# ── Postgres — same instance used by compass-workers ──────────────────────────
PG_DSN=postgresql://postgres:@localhost:5433/compass

# ── Run-loop ──────────────────────────────────────────────────────────────────
BATCH_SIZE=5000
POLL_SEC=5.0
