# syntax=docker/dockerfile:1.7
#
# compass-worker:cost — Cost lens worker.
# Identical content to :base; only the default CMD differs.
#
# Build (after building :base):
#   docker build -f compass-workers/Dockerfile.cost -t compass-worker:cost .

FROM compass-worker:base
ENTRYPOINT ["python", "run_worker.py", "--worker", "cost"]
