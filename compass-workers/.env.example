# ClickHouse
CH_HOST=localhost
CH_PORT=8123
CH_DB=compass
CH_USER=default
CH_PASSWORD=

# Postgres (used by Cost lens for pricing rates)
PG_DSN=postgresql://postgres:@localhost:5433/compass

# Worker run loop
WORKER_BATCH=5000
WORKER_POLL_SEC=2.0

WORKER_BATCH_PERFORMANCE=5000
WORKER_BATCH_COST=5000
WORKER_BATCH_SAFETY=1000
WORKER_BATCH_QUALITY=600

WORKER_POLL_SEC_PERFORMANCE=2.0
WORKER_POLL_SEC_COST=2.0
WORKER_POLL_SEC_SAFETY=5.0
WORKER_POLL_SEC_QUALITY=120.0

COMPASS_PII_NER_MODEL=gravitee-io/bert-small-pii-detection
COMPASS_PII_BATCH_SIZE=4
COMPASS_PII_CACHE_MAX=20000

COMPASS_TOXICITY_BATCH_SIZE=32
COMPASS_TOXICITY_CACHE_MAX=10000

# ── Toxicity — device + perf ─────────────────────────────────────
COMPASS_TOXICITY_DEVICE=cuda
COMPASS_TOXICITY_ONNX_PROVIDER=auto
COMPASS_TOXICITY_MAX_LENGTH=512
COMPASS_TOXICITY_FP16=true
COMPASS_TOXICITY_BATCH_SIZE=32

# ── Toxicity — model paths ───────────────────────────────────────
# Set the root once; the four paths below are relative to it unless
# absolute. In a container with /opt/models mounted, set the root and
# leave the rest at defaults.
COMPASS_TOXICITY_MODELS_ROOT=/opt/models
COMPASS_TOXICITY_PI_PATH=prompt_injection
COMPASS_TOXICITY_MOD_PATH=minilm_toxic_spam


# ── Toxicity — BERT review thresholds (drive 0/1 verdicts) ──────
COMPASS_TOXICITY_PI_THRESHOLD=0.50
COMPASS_TOXICITY_HARMFUL_THRESHOLD=0.50

# ── Quality — gate + sampling ────────────────────────────
COMPASS_QUALITY_SEMANTIC=true
COMPASS_QUALITY_SAMPLE=1.0
COMPASS_QUALITY_CACHE_MAX=20000

# ── Quality — runtime ────────────────────────────────────
COMPASS_QUALITY_DEVICE=cpu
COMPASS_QUALITY_BATCH=32

# ── Quality — model paths ────────────────────────────────
COMPASS_QUALITY_MODELS_ROOT=/opt/models
COMPASS_QUALITY_NLI_PATH=nli
COMPASS_QUALITY_EMBED_PATH=embedding
COMPASS_QUALITY_RELEVANCE_PATH=relevance


# ── Quality — recipe knobs (overridable; defaults match constants.py) ──
COMPASS_QUALITY_PREMISE_MAX_CHARS=2000
COMPASS_QUALITY_MAX_SENTS=10
COMPASS_QUALITY_SENT_MIN_CHARS=3
COMPASS_QUALITY_CHUNK_USED_COS=0.5