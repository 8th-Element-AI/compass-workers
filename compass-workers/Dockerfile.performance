# syntax=docker/dockerfile:1.7
#
# compass-worker:performance — Performance lens worker.
# Identical content to :base; only the default CMD differs.
#
# Build (after building :base):
#   docker build -f compass-workers/Dockerfile.performance -t compass-worker:performance .

FROM compass-worker:base
ENTRYPOINT ["python", "run_worker.py", "--worker", "performance"]